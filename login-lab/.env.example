# Username for the built-in lab account.
LAB_USERNAME="test_user"

# Password for the built-in lab account.
LAB_PASSWORD="correct horse battery staple"

# Number of failed logins before the account is locked.
ACCOUNT_MAX_FAILURES=5

# How long the account stays locked, in seconds.
ACCOUNT_LOCKOUT_SECONDS=300

# Number of login attempts allowed per IP address in one window.
IP_MAX_ATTEMPTS=20

# Length of the IP rate-limit window, in seconds.
IP_WINDOW_SECONDS=60

# Port used by the Flask app when started locally.
PORT=5000

# Set a value to 0 to disable the corresponding control.