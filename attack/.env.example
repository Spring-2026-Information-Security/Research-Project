# Default attack mode: cli, web, or both.
ATTACK_MODE=both

# Base URL for the login lab API and browser UI.
ATTACK_BASE_URL=http://127.0.0.1:5000

# Username to target during the attack run.
ATTACK_USERNAME=test_user

# Root folder used when discovering generated password lists.
ATTACK_GENERATED_ROOT=passwords/raw

# File glob used while scanning the generated root.
ATTACK_PATTERN=*.txt

# Maximum passwords to try across all input files. Use 0 for unlimited.
ATTACK_MAX_PASSWORDS=0

# Delay in seconds between attempts.
ATTACK_DELAY=0

# Reset the lab automatically when lockout or rate limiting blocks the run.
ATTACK_AUTO_RESET_ON_BLOCK=true

# Keep lines beginning with # instead of treating them as comments.
ATTACK_KEEP_COMMENT_LINES=false

# Optional override for a fixed output directory. Leave unset to use a timestamped folder.
# ATTACK_LOG_DIR=attack/logs/custom-run